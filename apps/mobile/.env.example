# AI4U Little Engineer — Mobile App Environment Variables
# Copy this file to .env.local and fill in the values.
# All EXPO_PUBLIC_ variables are bundled into the app at build time.

# Supabase (get from Supabase dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API base URL (your Vercel deployment)
EXPO_PUBLIC_API_BASE_URL=https://ai4u-little-engineer-web.vercel.app
