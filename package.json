{
  "name": "ai4u-little-engineer",
  "version": "0.1.0",
  "private": true,
  "description": "AI4U Little Engineer — Voice-to-CAD phone-first web app for machinists",
  "workspaces": [
    "apps/web",
    "apps/trigger",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=./apps/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "trigger:dev": "turbo run dev --filter=./apps/trigger",
    "trigger:deploy": "turbo run deploy --filter=./apps/trigger",
    "compliance": "bash scripts/compliance.sh",
    "eval:live": "python3 scripts/eval-live.py"
  },
  "devDependencies": {
    "@trigger.dev/sdk": "^4.4.3",
    "@types/jest": "^30.0.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
