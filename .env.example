# ═══════════════════════════════════════════════════════════════
# AI4U Little Engineer — Environment Variables Template
# Copy this file to .env.local (web app) or .env (services)
# NEVER commit actual secrets to version control
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# Supabase (required for all services)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # SERVER ONLY — never expose to client
SUPABASE_URL=https://your-project.supabase.co    # For server-side / Trigger.dev

# ─────────────────────────────────────────────────────────────
# LLM Provider (Fix F: choose Gemini or OpenAI)
# ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER=gemini to use Gemini Live + function-calling (recommended)
# Set LLM_PROVIDER=openai to use Whisper + GPT-4.1 JSON (default / fallback)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini  # Only used when LLM_PROVIDER=openai

# ─────────────────────────────────────────────────────────────
# Google AI (required when LLM_PROVIDER=gemini)
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...  # Google AI Studio API key

# ─────────────────────────────────────────────────────────────
# OpenAI (required for Whisper transcription regardless of LLM_PROVIDER)
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────
# CAD Worker (required for generation)
# ─────────────────────────────────────────────────────────────
CAD_WORKER_URL=http://localhost:8080  # Local dev; use Cloud Run URL in production
CAD_WORKER_API_KEY=                   # Optional: shared secret for worker auth

# ─────────────────────────────────────────────────────────────
# Trigger.dev (required for background jobs)
# ─────────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY=tr_...
TRIGGER_PROJECT_ID=ai4u-little-engineer
TRIGGER_API_URL=https://api.trigger.dev  # Default

# ─────────────────────────────────────────────────────────────
# Webhooks
# ─────────────────────────────────────────────────────────────
WEBHOOK_SECRET=your-random-webhook-secret-min-32-chars
WEB_APP_WEBHOOK_URL=https://your-app.vercel.app/api/webhooks/cad-worker

# ─────────────────────────────────────────────────────────────
# Sentry (optional but recommended for production)
# ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...  # For client-side errors

# ─────────────────────────────────────────────────────────────
# Vercel (for deployment)
# ─────────────────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ─────────────────────────────────────────────────────────────
# CAD Worker specific (set in Docker / Cloud Run)
# ─────────────────────────────────────────────────────────────
ARTIFACTS_DIR=/app/artifacts
ALLOWED_ORIGINS=https://your-app.vercel.app
DEBUG=false

# ─────────────────────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────────────────────
ENABLE_FREECAD_ADAPTER=false  # Set true only when FreeCAD is installed

# ─────────────────────────────────────────────────────────────
# Supabase Storage (CAD worker upload — Fix C)
# ─────────────────────────────────────────────────────────────
# The CAD worker needs SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY to upload
# artifacts directly to the cad-artifacts bucket. Set these in the Cloud Run
# service environment (same values as above, repeated for clarity).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
